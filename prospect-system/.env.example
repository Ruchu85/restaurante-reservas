# ============================================================
# PROSPECT SYSTEM — Configuración
# Copia este archivo a .env y rellena tus valores reales
# ============================================================

# --- Google Places API (obligatorio para prospección) ---
# Consigue tu clave en: https://console.cloud.google.com
# Activa la API: Places API (Legacy) o Places API (New)
GOOGLE_PLACES_API_KEY=

# --- Hunter.io (opcional — mejora la búsqueda de emails) ---
# Free tier: 25 búsquedas/mes en https://hunter.io
HUNTER_API_KEY=

# --- Email — Brevo (obligatorio para envío real) ---
# Regístrate en https://app.brevo.com — 300 emails/día gratis
BREVO_API_KEY=

# --- Identidad del remitente ---
SENDER_NAME=Tu Nombre
SENDER_EMAIL=tu@email.com
SENDER_REPLY_TO=tu@email.com

# --- Comportamiento ---
# DRY_RUN=true → los emails se generan pero NUNCA se envían (por defecto siempre)
# Cambia a false SOLO cuando quieras enviar emails reales y hayas revisado los borradores
DRY_RUN=true

# Máximo de emails enviados por ejecución
DAILY_EMAIL_LIMIT=50

# Pausa entre llamadas a APIs externas (ms) — respeta rate limits
REQUEST_DELAY_MS=1500

# Reintentos en caso de error de red
MAX_RETRIES=3

# --- Base de datos ---
# SQLite local por defecto; cambia a postgresql+psycopg2://... para Postgres
DATABASE_URL=sqlite:///data/leads.db

# --- Logs ---
LOG_LEVEL=INFO
LOG_FILE=logs/prospect.log
