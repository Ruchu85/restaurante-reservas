# Supabase — obtenidos en https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Sólo necesario para scripts de servidor o migraciones (nunca en el cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL base de la app (sin barra final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Slug del salón por defecto (debe coincidir con el valor en la tabla salons)
NEXT_PUBLIC_SALON_SLUG=salon-demo

# Cadena de conexión directa a Postgres (opcional, para tooling SQL / migraciones manuales)
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Base URL para los tests E2E de Playwright
PLAYWRIGHT_BASE_URL=http://localhost:3000
