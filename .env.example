# Supabase — obtenidos en https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Sólo necesario para scripts de servidor (nunca en el cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL base de la app (sin barra final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Slug del restaurante por defecto (debe coincidir con la tabla restaurants)
NEXT_PUBLIC_RESTAURANT_SLUG=restaurante-demo
